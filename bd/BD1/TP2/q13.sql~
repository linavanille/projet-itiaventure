SELECT P1.NUM_PRODUCTEUR, P1.NOM
FROM PRODUCTEURS P1
WHERE NOT EXISTS
      (SELECT *
      FROM VINS
      WHERE NOT EXISTS
      	    (SELECT *
	    FROM RECOLTES, PRODUCTEURS P2
	    WHERE P2.NUM_PRODUCTEUR = 35
	    	  AND P1.NUM_PRODUCTEUR = PRODUCTEUR
		  AND NUM_VIN = VIN
            )
       )
;
